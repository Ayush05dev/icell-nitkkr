# Backend Environment Variables Template
# Copy this to .env and fill in your actual values

# ==================== Server Configuration ====================
PORT=5000
NODE_ENV=development

# ==================== Database ====================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# ==================== JWT Secrets ====================
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_min_32_chars

# ==================== Frontend URLs ====================
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:5000

# ==================== Mailjet Configuration ====================
MAILJET_API_KEY=467e0fb7b1217a86b2dd25f8d618af22
MAILJET_API_SECRET=6211dcd0672aae6f8197485deb113791
MAILJET_FROM_EMAIL=icellnitkkrtech@gmail.com
MAILJET_FROM_NAME=NITKKR

# ==================== Optional Email Configuration ====================
# Fallback sender info (if Mailjet env vars not set)
SMTP_FROM=noreply@nitkkr.ac.in

# Email send timeout in milliseconds
EMAIL_SEND_TIMEOUT_MS=15000

# ==================== Admin Configuration ====================
# Default admin email for setup-admin script
ADMIN_EMAIL=admin@nitkkr.ac.in
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin User

# ==================== Optional: For Testing ====================
# Toggle email sending (set to "false" to skip email during testing)
SEND_EMAILS=true
